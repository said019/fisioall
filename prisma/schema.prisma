// ── Horarios por usuario (Feature 2 — Kaya Kalp) ──────────────────────────── //

model HorarioUsuario {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id") @db.Uuid
  usuarioId String   @map("usuario_id") @db.Uuid
  diaKey    String   @map("dia_key") @db.VarChar(20) // "lunes" | "martes" | ... | "domingo"
  franjas   Json     // [{ inicio: "09:00", fin: "13:00" }, { inicio: "16:00", fin: "19:00" }]
  activo    Boolean  @default(true)
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([tenantId, usuarioId, diaKey])
  @@map("horarios_usuario")
}

model CubiculoUsuario {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id") @db.Uuid
  usuarioId    String   @map("usuario_id") @db.Uuid
  tipoSesion   String   @map("tipo_sesion") @db.VarChar(60) // "fisioterapia" | "suelo_pelvico" | "cosme" | "ejercicio"
  cubiculoPref Int[]    @map("cubiculo_pref") // [2, 1] → preferido 2, fallback 1
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([tenantId, usuarioId, tipoSesion])
  @@map("cubiculos_usuario")
}

// ── Expedientes especializados (Feature 3 — Kaya Kalp) ────────────────────── //

model ExpedienteEspecializado {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id") @db.Uuid
  pacienteId String   @map("paciente_id") @db.Uuid
  tipo       String   @db.VarChar(30) // "fisioterapia" | "suelo_pelvico" | "cosme"
  esInicial  Boolean  @default(true) @map("es_inicial")
  datosJson  Json     @map("datos_json")
  citaId     String?  @map("cita_id") @db.Uuid
  creadoPor  String   @map("creado_por") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  paciente Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  cita     Cita?    @relation(fields: [citaId], references: [id], onDelete: SetNull)
  creador  Usuario  @relation(fields: [creadoPor], references: [id])

  @@index([tenantId])
  @@index([pacienteId])
  @@map("expedientes_especializados")
}

// ── Body Map Snapshots (sistema de seguimiento clínico) ───────────────────── //

model BodyMapSnapshot {
  id         String              @id @default(uuid())
  pacienteId String              @map("paciente_id")
  tenantId   String              @map("tenant_id")
  citaId     String?             @map("cita_id")
  tipo       SnapshotTipo
  sesionNum  Int                 @map("sesion_num")
  notas      String?
  createdAt  DateTime            @default(now()) @map("created_at")

  marcas     BodyMapMarcaSnap[]

  @@index([pacienteId, createdAt])
  @@index([tenantId])
  @@map("body_map_snapshot")
}

model BodyMapMarcaSnap {
  id          String          @id @default(uuid())
  snapshotId  String          @map("snapshot_id")
  zonaId      String          @map("zona_id")
  zonaLabel   String          @map("zona_label")
  vista       VistaBody
  tipo        TipoHallazgo
  intensidad  Int
  lateralidad Lateralidad
  notas       String?
  colorHex    String          @default("#EF4444") @map("color_hex")

  snapshot    BodyMapSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
  @@map("body_map_marca_snap")
}

enum SnapshotTipo {
  evaluacion_inicial
  seguimiento
  reevaluacion
}

enum VistaBody {
  anterior
  posterior
  lateral_der
  lateral_izq
}

enum TipoHallazgo {
  dolor
  inflamacion
  contractura
  limitacion_rom
  parestesia
  tension_muscular
}

enum Lateralidad {
  bilateral
  izquierdo
  derecho
}

enum TarjetaLealtadEstado {
  activa
  completada
  canjeada
  expirada
}

model GoogleCalendarToken {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @unique @map("tenant_id") @db.Uuid
  accessToken   String    @map("access_token")
  refreshToken  String    @map("refresh_token")
  tokenExpiry   DateTime  @map("token_expiry") @db.Timestamptz
  email         String?   @db.VarChar(150)
  calendarId    String?   @default("primary") @map("calendar_id") @db.VarChar(200)
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("google_calendar_tokens")
}

model TarjetaLealtad {
  id              String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String                @map("tenant_id") @db.Uuid
  pacienteId      String                @map("paciente_id") @db.Uuid
  sellosTotal     Int                   @map("sellos_total")
  sellosUsados    Int                   @default(0) @map("sellos_usados")
  recompensa      String                @db.VarChar(255)
  estado          TarjetaLealtadEstado  @default(activa)
  fechaCreacion   DateTime              @default(now()) @map("fecha_creacion") @db.Date
  fechaExpiracion DateTime?             @map("fecha_expiracion") @db.Date
  notas           String?

  walletApplePassId   String?           @map("wallet_apple_pass_id") @db.VarChar(100)
  walletGoogleSaveUrl String?           @map("wallet_google_save_url")

  createdAt       DateTime?             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime?             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  paciente        Paciente              @relation(fields: [pacienteId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([pacienteId])
  @@map("tarjetas_lealtad")
}
